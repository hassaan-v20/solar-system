; Engine configuration file.
; Stellar — Ghost Station vertical slice. See ../docs/ARCHITECTURE.md.

config_version=5

[application]

config/name="Stellar"
config/description="Co-op space raid extraction — Ghost Station vertical slice."
run/main_scene="res://scenes/title.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

EventBus="*res://scripts/core/event_bus.gd"
GameState="*res://scripts/core/game_state.gd"

[display]

window/size/viewport_width=1600
window/size/viewport_height=900
; Launch straight into (borderless) fullscreen. F11 / controller Create button
; toggles back to a window — see GameState._setup_fullscreen_toggle().
window/size/mode=3

[gui]

theme/custom_font="res://assets/fonts/Orbitron.ttf"

[rendering]

environment/defaults/default_clear_color=Color(0.015, 0.02, 0.04, 1)
